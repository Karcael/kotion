# Veritabanı bağlantısı (Docker kullanıyorsanız değiştirmenize gerek yok)
DATABASE_URL="postgresql://kotion:kotion@localhost:5432/kotion"

# JWT şifreleme anahtarı (üretimde mutlaka değiştirin!)
JWT_SECRET="kotion-super-secret-jwt-key-change-in-production"

# Uygulama URL'si (Cloudflare Tunnel kullanıyorsanız subdomain adresiniz)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Docker dış port (3000 doluysa değiştirin)
APP_PORT=3000
